generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider     = "postgresql"
  relationMode = "prisma"
}

model sessions {
  id         String   @id
  user_id    Int
  expires_at DateTime
  created_at DateTime @default(now())
  user       users    @relation(fields: [user_id], references: [id])
}

model users {
  id                  Int                   @id @default(autoincrement())
  email               String                @unique
  password_hash       String?
  short_name          String
  department          String
  role                String
  is_active           Boolean               @default(true)
  created_at          DateTime              @default(now())
  updated_at          DateTime
  status              String                @default("PENDING_VERIFICATION")
  cost_center         String
  sessions            sessions[]
  verification_tokens verification_tokens[]
  reset_tokens        reset_tokens[]
  created_bills       utility_bills[]       @relation("CreatedBills")
  approved_bills      utility_bills[]       @relation("ApprovedBills")
  notifications       notifications[]
}

model utility_bills {
  id                 Int       @id @default(autoincrement())
  billing_year       Int?
  billing_month      Int?
  amount             Float
  reference_no       String
  note               String?
  created_by         Int
  created_at         DateTime  @default(now())
  updated_at         DateTime
  status             String
  approved_by        Int?
  approved_at        DateTime?
  budget_code        String?
  cost_center        String?
  document_date      DateTime?
  document_no        String?
  document_type       String?
  receipt_file_url    String?
  direct_pay_file_url String?
  ktb_file_url        String?
  gl_code             String?
  invoice_date       DateTime?
  invoice_year       Int?
  invoice_month      Int?
  meter_no           String?
  own_agency         String?
  payer_receive_date DateTime?
  proxy_agency       String?
  proxy_send_date    DateTime?
  receive_date       DateTime?
  reject_reason      String?
  
  creator            users     @relation("CreatedBills", fields: [created_by], references: [id])
  approver           users?    @relation("ApprovedBills", fields: [approved_by], references: [id])
}

model utility_types {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  name_th    String
  name_en    String
  unit       String
  icon       String
  color      String
  created_at DateTime @default(now())
}

model verification_tokens {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model reset_tokens {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
  user       users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model notifications {
  id          Int      @id @default(autoincrement())
  user_id     Int
  title       String
  message     String
  type        String   // 'NEW_REPORT', 'STATUS_CHANGE'
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())
  bill_id     Int?
  user        users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
